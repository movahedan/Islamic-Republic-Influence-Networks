{
	"$schema": "https://biomejs.dev/schemas/2.4.5/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true,
		"defaultBranch": "main"
	},
	"files": {
		"ignoreUnknown": false,
		"includes": [
			"extension/**/*",
			"!extension/src/data/handles.json",
			"!bun.lock",
			"!**/node_modules",
			"!**/dist",
			"!**/build"
		]
	}
}
